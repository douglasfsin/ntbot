@inherits LayoutComponentBase
@implements IDisposable
@inject AuthSession Session
@inject JwtAuthStateProvider AuthState
@inject NavigationManager Nav
@inject HealthApiClient HealthApi

<div class="app-shell">
    <aside class="sidebar">
        <div class="sidebar-brand">
            NTBot <span class="accent">Pro</span>
        </div>
        <nav class="sidebar-nav">
            @foreach (var item in NavItems)
            {
                <NavLink class="nav-item" href="@item.Href" Match="@item.Match">
                    @item.Label
                </NavLink>
            }
        </nav>
        <div class="sidebar-footer">
            @if (Session.User != null)
            {
                <div class="user-meta">@Session.User.FullName</div>
                <div class="user-meta small">@Session.User.Email</div>
            }
            <button class="logout-btn" @onclick="Logout">Sair</button>
        </div>
    </aside>

    <div class="app-main">
        <header class="app-header">
            <div class="header-left">
                <span class="connection-dot @(IsConnected ? "online" : "")"></span>
                <span class="connection-label">@(IsConnected ? "API online" : "API offline")</span>
            </div>
            <div class="header-right">
                @if (Session.Tenant is not null)
                {
                    <span class="nt-badge nt-badge-success" style="margin-right:0.75rem;">@Session.Tenant.Plan</span>
                }
                <select class="symbol-select">
                    <option>MNQ</option>
                    <option>WIN</option>
                    <option>ES</option>
                </select>
            </div>
        </header>
        <main class="app-content">
            @Body
        </main>
    </div>
</div>

@code {
    private bool IsConnected;
    private Timer? _healthTimer;

    private readonly NavEntry[] NavItems =
    [
        new("/app", "Dashboard", NavLinkMatch.All),
        new("/app/scalping", "Scalping", NavLinkMatch.Prefix),
        new("/app/grid", "Grid Manager", NavLinkMatch.Prefix),
        new("/app/positions", "Positions", NavLinkMatch.Prefix),
        new("/app/risk", "Risk Mgmt", NavLinkMatch.Prefix),
        new("/app/wyckoff", "Wyckoff", NavLinkMatch.Prefix),
        new("/app/macro", "Macro", NavLinkMatch.Prefix),
        new("/app/quant", "Quant", NavLinkMatch.Prefix),
        new("/app/profitchart", "ProfitChart", NavLinkMatch.Prefix),
        new("/app/signals", "Sinais", NavLinkMatch.Prefix),
        new("/app/trades", "Trades", NavLinkMatch.Prefix),
        new("/app/settings", "Config", NavLinkMatch.Prefix),
    ];

    private record NavEntry(string Href, string Label, NavLinkMatch Match);

    protected override async Task OnInitializedAsync()
    {
        await CheckHealthAsync();
        _healthTimer = new Timer(async _ => await InvokeAsync(CheckHealthAsync), null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task CheckHealthAsync()
    {
        try
        {
            var health = await HealthApi.GetHealthAsync();
            IsConnected = health?.Status == "healthy";
        }
        catch
        {
            IsConnected = false;
        }
        StateHasChanged();
    }

    private void Logout()
    {
        Session.Clear();
        AuthState.NotifyAuthChanged();
        Nav.NavigateTo("/auth/signout-cookie", forceLoad: true);
    }

    public void Dispose() => _healthTimer?.Dispose();
}
