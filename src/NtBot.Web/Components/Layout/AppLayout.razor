@inherits LayoutComponentBase
@implements IDisposable
@inject AuthSession Session
@inject JwtAuthStateProvider AuthState
@inject NavigationManager Nav
@inject HealthApiClient HealthApi
@inject MacroApiClient MacroApi
@inject AuthSignInService SignIn

<div class="app-shell">
    <aside class="sidebar">
        <div class="sidebar-brand">
            NTBot <span class="accent">Pro</span>
        </div>
        <nav class="sidebar-nav">
            @foreach (var item in NavItems)
            {
                <NavLink class="nav-item" href="@item.Href" Match="@item.Match">
                    @item.Label
                </NavLink>
            }
        </nav>
        <div class="sidebar-footer">
            @if (Session.User != null)
            {
                <div class="user-meta">@Session.User.FullName</div>
                <div class="user-meta small">@Session.User.Email</div>
            }
            <button class="logout-btn" @onclick="Logout">Sair</button>
        </div>
    </aside>

    <div class="app-main">
        <header class="app-header">
            <div class="header-left">
                <span class="connection-dot @(IsConnected ? "online" : "")"></span>
                <span class="connection-label">@(IsConnected ? "API online" : "API offline")</span>
            </div>
            <div class="header-right">
                @if (_macroScore is not null)
                {
                    <span class="nt-badge @MacroScoreBadgeClass" style="margin-right:0.75rem;" title="Macro Score">
                        @MacroDisplay.Regime(_macroScore) · @_macroConfidence.ToString("F0")%
                    </span>
                }
                @if (Session.Tenant is not null)
                {
                    <span class="nt-badge nt-badge-success" style="margin-right:0.75rem;">@Session.Tenant.Plan</span>
                }
            </div>
        </header>
        <main class="app-content">
            @Body
        </main>
    </div>
</div>

@code {
    private bool IsConnected;
    private Timer? _healthTimer;
    private string? _macroScore;
    private decimal _macroConfidence;

    private readonly NavEntry[] NavItems =
    [
        new("/app", "Dashboard", NavLinkMatch.All),
        new("/app/macro", "Macro Intelligence", NavLinkMatch.Prefix),
        new("/app/macro/calendar", "Economic Calendar", NavLinkMatch.Prefix),
        new("/app/macro/market", "Market Overview", NavLinkMatch.Prefix),
        new("/app/market", "Market Intelligence", NavLinkMatch.Prefix),
        new("/app/quant", "Quant Strategy", NavLinkMatch.Prefix),
        new("/app/risk", "Risk Mgmt", NavLinkMatch.Prefix),
        new("/app/settings", "Configurações", NavLinkMatch.Prefix),
    ];

    private string MacroScoreBadgeClass => _macroScore switch
    {
        "Bullish" => "nt-badge-success",
        "Bearish" => "nt-badge-danger",
        _ => ""
    };

    private record NavEntry(string Href, string Label, NavLinkMatch Match);

    protected override async Task OnInitializedAsync()
    {
        SignIn.HydrateSession(Session);
        await CheckHealthAsync();
        await LoadMacroBadgeAsync();
        _healthTimer = new Timer(async _ => await InvokeAsync(CheckHealthAsync), null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task LoadMacroBadgeAsync()
    {
        try
        {
            var snapshot = await MacroApi.GetCurrentAsync();
            if (snapshot is not null)
            {
                _macroScore = snapshot.MacroScore;
                _macroConfidence = snapshot.Confidence;
            }
        }
        catch
        {
            // optional badge
        }
    }

    private async Task CheckHealthAsync()
    {
        try
        {
            var health = await HealthApi.GetHealthAsync();
            IsConnected = health?.Status == "healthy";
        }
        catch
        {
            IsConnected = false;
        }
        StateHasChanged();
    }

    private void Logout()
    {
        Session.Clear();
        AuthState.NotifyAuthChanged();
        Nav.NavigateTo("/auth/signout-cookie", forceLoad: true);
    }

    public void Dispose() => _healthTimer?.Dispose();
}
