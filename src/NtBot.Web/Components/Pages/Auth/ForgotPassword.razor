@page "/forgot-password"
@layout MainLayout
@rendermode InteractiveServer
@using NtBot.Identity.Dtos
@inject AuthApiClient AuthApi
@inject NavigationManager Nav

<PageTitle>Recuperar senha — NTBot</PageTitle>

<section class="auth-page">
    <div class="auth-card">
        <h1>Recuperar senha</h1>
        @if (_sent)
        {
            <p class="auth-sub">Se o email existir, enviamos um código. <a href="/reset-password">Inserir código</a></p>
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="HandleSubmit">
                <div class="auth-field">
                    <label>Email</label>
                    <InputText @bind-Value="_model.Email" class="auth-input" />
                </div>
                @if (!string.IsNullOrEmpty(_error)) { <div class="auth-error">@_error</div> }
                <button type="submit" class="auth-btn" disabled="@_loading">Enviar código</button>
            </EditForm>
        }
        <p class="auth-links"><a href="/login">Voltar ao login</a></p>
    </div>
</section>

@code {
    private readonly ForgotPasswordRequest _model = new();
    private string? _error;
    private bool _loading;
    private bool _sent;

    private async Task HandleSubmit()
    {
        _loading = true;
        _error = null;
        try
        {
            var result = await AuthApi.ForgotPasswordAsync(_model);
            if (result?.Success == true)
            {
                _sent = true;
                Nav.NavigateTo($"/reset-password?email={Uri.EscapeDataString(_model.Email)}");
            }
            else _error = result?.Message ?? "Erro ao enviar código";
        }
        finally { _loading = false; }
    }
}
