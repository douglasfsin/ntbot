@page "/reset-password"
@layout MainLayout
@rendermode InteractiveServer
@using NtBot.Identity.Dtos
@inject AuthApiClient AuthApi
@inject NavigationManager Nav

<PageTitle>Nova senha — NTBot</PageTitle>

<section class="auth-page">
    <div class="auth-card">
        <h1>Nova senha</h1>
        <EditForm Model="_model" OnValidSubmit="HandleSubmit">
            <div class="auth-field">
                <label>Email</label>
                <InputText @bind-Value="_model.Email" class="auth-input" />
            </div>
            <div class="auth-field">
                <label>Código OTP</label>
                <InputText @bind-Value="_model.OtpCode" class="auth-input" maxlength="6" />
            </div>
            <div class="auth-field">
                <label>Nova senha</label>
                <InputText @bind-Value="_model.NewPassword" type="password" class="auth-input" />
            </div>
            @if (!string.IsNullOrEmpty(_message)) { <div class="auth-success">@_message</div> }
            @if (!string.IsNullOrEmpty(_error)) { <div class="auth-error">@_error</div> }
            <button type="submit" class="auth-btn" disabled="@_loading">Alterar senha</button>
        </EditForm>
    </div>
</section>

@code {
    private readonly ResetPasswordRequest _model = new();
    private string? _error;
    private string? _message;
    private bool _loading;

    [SupplyParameterFromQuery] public string? Email { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Email))
            _model.Email = Email;
    }

    private async Task HandleSubmit()
    {
        _loading = true;
        _error = null;
        try
        {
            var result = await AuthApi.ResetPasswordAsync(_model);
            if (result?.Success == true)
            {
                _message = result.Message;
                Nav.NavigateTo("/login");
                return;
            }
            _error = result?.Message ?? "Erro ao alterar senha";
        }
        finally { _loading = false; }
    }
}
