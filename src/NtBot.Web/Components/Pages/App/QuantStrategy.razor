@page "/app/quant"
@layout AppLayout
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject QuantStrategyApiClient QuantApi
@inject MarketApiClient MarketApi
@inject MarketHubService MarketHub
@inject MarketDriversApiClient DriversApi

<PageTitle>Quant — NTBot</PageTitle>

<div class="app-page">
    <header class="app-page-header">
        <div>
            <h1>Estratégia Quantitativa</h1>
            <p class="app-page-sub">Correlação global · GEX · Wyckoff</p>
        </div>
        <div class="app-page-actions">
            @if (_lastUpdatedUtc is not null)
            {
                <span class="app-muted" style="font-size:0.85rem;align-self:center;">
                    Atualizado @_lastUpdatedUtc.Value.ToLocalTime().ToString("HH:mm:ss")
                </span>
            }
            <select class="app-select" @bind="_symbol" @bind:after="OnSymbolChangedAsync">
                @foreach (var sym in _symbolOptions)
                {
                    <option value="@sym.Key">@sym.Value</option>
                }
            </select>
            <button class="nt-btn nt-btn-primary" @onclick="() => LoadAsync()" disabled="@_loading">Atualizar</button>
        </div>
    </header>

    @if (_loading && _data is null)
    {
        <p class="app-muted">Carregando dashboard quant...</p>
    }
    else if (_error is not null)
    {
        <div class="nt-card app-error">@_error</div>
    }
    else if (_data is not null)
    {
        @if (!_data.DataAvailable)
        {
            <div class="nt-card app-error" style="margin-bottom:1rem;">
                @(_data.Message ?? "Dados OHLCV indisponíveis. Inicie o connector Windows com MT5.")
                <div class="app-muted" style="margin-top:0.5rem;font-size:0.85rem;">
                    Fonte: @_data.CandleSource · Líder: @_data.LeaderCandleSource
                </div>
                @if (_data.AvailableSymbols.Count > 0)
                {
                    <div class="app-muted" style="margin-top:0.5rem;font-size:0.85rem;">
                        Símbolos com candles: @string.Join(", ", _data.AvailableSymbols)
                    </div>
                }
            </div>
        }
        else
        {
            <p class="app-muted" style="margin:0 0 1rem;font-size:0.85rem;">
                Candles @_data.Symbol via @FormatSource(_data.CandleSource) · @_data.LeaderSymbol via @FormatSource(_data.LeaderCandleSource)
            </p>

        <div class="app-metrics">
            <div class="nt-card app-metric">
                <span class="app-metric-label">Preço @_data.Symbol</span>
                <span class="app-metric-value">@_data.CurrentPrice.ToString("N2")</span>
            </div>
            <div class="nt-card app-metric">
                <span class="app-metric-label">Correlação @_data.LeaderSymbol</span>
                <span class="app-metric-value @BiasClass(_data.Correlation?.LeaderBias)">
                    @(_data.Correlation?.PearsonCorrelation.ToString("P1") ?? "—")
                </span>
                <span class="app-metric-hint">Bias @(_data.Correlation?.LeaderBias ?? "—")</span>
            </div>
            <div class="nt-card app-metric">
                <span class="app-metric-label">Regime GEX</span>
                <span class="nt-badge @GexBadgeClass(_data.Gex?.Regime)">@(_data.Gex?.Regime ?? "—")</span>
                <span class="app-metric-hint">@GexDescription(_data.Gex?.Regime)</span>
            </div>
            <div class="nt-card app-metric">
                <span class="app-metric-label">Expansão / Mean Rev.</span>
                <span class="app-metric-value" style="font-size:1rem;">
                    @(_data.Gex?.ExpansionPotential.ToString("F0") ?? "0")% /
                    @(_data.Gex?.MeanReversionPotential.ToString("F0") ?? "0")%
                </span>
            </div>
        </div>

        @if (_data.Signal is not null)
        {
            <div class="nt-card" style="margin-top:1rem;border-left:3px solid var(--nt-accent);">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;flex-wrap:wrap;">
                    <div>
                        <h2 style="margin:0 0 0.5rem;font-size:1.125rem;">Sinal @_data.Signal.Direction</h2>
                        <p style="margin:0;color:var(--nt-text-secondary);">@_data.Signal.Description</p>
                    </div>
                    <span class="nt-badge nt-badge-success">Confiança @_data.Signal.ConfidenceScore.ToString("F0")%</span>
                </div>
                <div class="app-metrics" style="margin-top:1rem;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));">
                    <div><span class="app-metric-label">Entrada</span><div>@_data.Signal.EntryPrice.ToString("N2")</div></div>
                    <div><span class="app-metric-label">Stop</span><div style="color:var(--nt-danger)">@_data.Signal.StopLoss.ToString("N2")</div></div>
                    <div><span class="app-metric-label">Alvo 1</span><div style="color:var(--nt-success)">@_data.Signal.TakeProfit1.ToString("N2")</div></div>
                    <div><span class="app-metric-label">R:R</span><div>1:@_data.Signal.RiskRewardRatio.ToString("F1")</div></div>
                </div>
                @if (_data.Signal.Observations.Count > 0)
                {
                    <ul class="app-list" style="margin-top:1rem;">
                        @foreach (var obs in _data.Signal.Observations)
                        {
                            <li>@obs</li>
                        }
                    </ul>
                }
            </div>
        }
        else
        {
            <div class="nt-card app-muted" style="margin-top:1rem;">Nenhum sinal ativo no momento.</div>
        }

        @if (_correlation?.AssetImpacts.Count > 0 || _quantScore is not null)
        {
            <section style="margin-top:1.5rem;">
                <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:0.75rem;">
                    <h2 style="margin:0;font-size:1rem;">Commodities Impact</h2>
                    @if (_marketHubConnected)
                    {
                        <span class="nt-badge nt-badge-success">Market live</span>
                    }
                </div>
                <div style="display:grid;grid-template-columns:1fr 280px;gap:1rem;">
                    <CorrelationGrid Impacts="@(_correlation?.AssetImpacts ?? [])" />
                    <QuantScoreCard Score="_quantScore" />
                </div>
            </section>
        }

        @if (_driversSnapshot is not null)
        {
            <section style="margin-top:1.5rem;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;">
                    <h2 style="margin:0;font-size:1rem;">Market Drivers — @_driversSnapshot.Asset</h2>
                    <a href="/app/drivers/@_driversSnapshot.Asset" class="app-muted" style="font-size:0.85rem;">Detalhes →</a>
                </div>
                <MarketDriversCard Snapshot="_driversSnapshot" MaxDrivers="6" />
                <MarketDriversExplanation Explanation="@_driversSnapshot.Explanation" AiSummary="@_driversSnapshot.AiSummary" />
            </section>
        }

        @if (_data.Gex?.GammaWalls.Count > 0)
        {
            <div class="nt-card" style="margin-top:1rem;">
                <h2 style="margin:0 0 1rem;font-size:1rem;">Gamma Walls</h2>
                <div class="app-table-wrap">
                    <table class="app-table">
                        <thead>
                            <tr><th>Strike</th><th>Tipo</th><th>Concentração</th><th>Distância</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var wall in _data.Gex.GammaWalls.Take(8))
                            {
                                <tr>
                                    <td>@wall.Strike.ToString("N0")</td>
                                    <td>@wall.Type</td>
                                    <td>@wall.GammaConcentration.ToString("N2")</td>
                                    <td>@wall.Distance.ToString("P2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        }
    }
</div>

@code {
    private string _symbol = "WINFUT";
    private Dictionary<string, string> _symbolOptions = new()
    {
        ["WINFUT"] = "WIN (Ibovespa)",
        ["WDOFUT"] = "WDO (Dólar)"
    };
    private QuantDashboardModel? _data;
    private CorrelationResultModel? _correlation;
    private QuantScoreModel? _quantScore;
    private MarketDriversSnapshotModel? _driversSnapshot;
    private bool _loading = true;
    private bool _marketHubConnected;
    private string? _error;
    private DateTime? _lastUpdatedUtc;
    private CancellationTokenSource? _refreshCts;
    private Task? _refreshLoop;

    protected override async Task OnInitializedAsync()
    {
        MarketHub.CorrelationUpdated += OnCorrelationUpdated;
        MarketHub.QuantScoreUpdated += OnQuantScoreUpdated;

        try
        {
            await MarketHub.ConnectAsync();
            _marketHubConnected = MarketHub.IsConnected;
        }
        catch
        {
            _marketHubConnected = false;
        }

        await LoadSymbolOptionsAsync();
        await LoadAsync();
        await LoadMarketAsync();
        _refreshCts = new CancellationTokenSource();
        _refreshLoop = RunRefreshLoopAsync(_refreshCts.Token);
    }

    private async Task LoadSymbolOptionsAsync()
    {
        var available = await QuantApi.GetAvailableSymbolsAsync(50);
        var options = new Dictionary<string, string>(_symbolOptions, StringComparer.OrdinalIgnoreCase);

        foreach (var sym in available)
        {
            if (!options.ContainsKey(sym))
                options[sym] = sym;
        }

        _symbolOptions = options;
        if (!_symbolOptions.ContainsKey(_symbol) && _symbolOptions.Count > 0)
            _symbol = _symbolOptions.Keys.First();
    }

    private async Task OnSymbolChangedAsync() => await LoadAsync();

    private async Task RunRefreshLoopAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(60));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await LoadAsync(silent: true);
                await LoadMarketAsync(silent: true);
            }
        }
        catch (OperationCanceledException)
        {
            // page disposed
        }
    }

    private async Task LoadMarketAsync(bool silent = false)
    {
        try
        {
            _correlation = await MarketApi.GetCorrelationAsync();
            _quantScore = await MarketApi.GetQuantScoreAsync();
            _driversSnapshot = await DriversApi.GetSnapshotAsync(MapDriversSymbol(_symbol));
        }
        catch (Exception ex) when (!silent)
        {
            _error ??= ex.Message;
        }

        if (!silent)
            await InvokeAsync(StateHasChanged);
    }

    private void OnCorrelationUpdated(CorrelationResultModel correlation)
    {
        _correlation = correlation;
        _marketHubConnected = true;
        InvokeAsync(StateHasChanged);
    }

    private void OnQuantScoreUpdated(QuantScoreModel score)
    {
        _quantScore = score;
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync(bool silent = false)
    {
        if (!silent) _loading = true;
        _error = null;
        try
        {
            _data = await QuantApi.GetDashboardAsync(_symbol, "NQ");
            if (_data is null)
                _error = "Não foi possível carregar o dashboard quant.";
            else
                _lastUpdatedUtc = DateTime.UtcNow;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            if (!silent) _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string BiasClass(string? bias) => bias switch
    {
        "BULLISH" => "text-bull",
        "BEARISH" => "text-bear",
        _ => ""
    };

    private static string GexBadgeClass(string? regime) => regime switch
    {
        "NEGATIVE_HIGH" or "NEGATIVE_LOW" => "nt-badge-danger",
        "POSITIVE_HIGH" or "POSITIVE_LOW" => "nt-badge-success",
        _ => ""
    };

    private static string GexDescription(string? regime) => regime switch
    {
        "NEGATIVE_HIGH" => "Alta volatilidade — breakouts prováveis",
        "NEGATIVE_LOW" => "Início de expansão",
        "POSITIVE_HIGH" => "Forte compressão — mean reversion",
        "POSITIVE_LOW" => "Transição — compressão leve",
        _ => "Mercado neutro"
    };

    private static string FormatSource(string? source) => source switch
    {
        "database" => "cache DB",
        "database-stale" => "cache DB (desatualizado)",
        "mt5" => "MT5",
        "mt5-partial" => "MT5 (parcial)",
        "unavailable" or "" or null => "indisponível",
        _ => source
    };

    private static string MapDriversSymbol(string symbol) => symbol.ToUpperInvariant() switch
    {
        "WINFUT" or "WIN$" or "IND" => "WIN",
        "WDOFUT" or "DOL" => "WDO",
        "XAU" or "GOLD" => "XAUUSD",
        _ => symbol.ToUpperInvariant()
    };

    public async ValueTask DisposeAsync()
    {
        MarketHub.CorrelationUpdated -= OnCorrelationUpdated;
        MarketHub.QuantScoreUpdated -= OnQuantScoreUpdated;
        _refreshCts?.Cancel();
        _refreshCts?.Dispose();
        await MarketHub.DisposeAsync();
    }
}
