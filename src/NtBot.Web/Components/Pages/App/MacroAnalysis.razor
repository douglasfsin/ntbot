@page "/app/macro"
@layout AppLayout
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject MacroApiClient MacroApi
@inject MacroHubService MacroHub
@inject AuthSignInService SignIn
@inject AuthSession Session
@inject NavigationManager Nav

<PageTitle>Macro Intelligence — NTBot</PageTitle>

<div class="app-page">
    <header class="app-page-header">
        <div>
            <h1>Macro Intelligence</h1>
            <p class="app-page-sub">Regime macro, indicadores FRED, calendário e recomendações</p>
        </div>
        <div class="app-page-actions">
            @if (_hubConnected)
            {
                <span class="nt-badge nt-badge-success">Tempo real</span>
            }
            <select class="app-select" @bind="_symbol" @bind:after="OnSymbolChangedAsync">
                <option value="MNQ">MNQ</option>
                <option value="ES">ES</option>
                <option value="NQ">NQ</option>
                <option value="WINFUT">WINFUT</option>
            </select>
            <button class="nt-btn nt-btn-primary" @onclick="LoadAsync" disabled="@_loading">Atualizar</button>
        </div>
    </header>

    @if (_loading && _snapshot is null)
    {
        <p class="app-muted">Carregando macro intelligence...</p>
    }
    else if (_error is not null)
    {
        <div class="nt-card app-error">@_error</div>
    }
    else
    {
        <div class="macro-page-grid">
            <MacroScoreCard MacroScore="_snapshot?.MacroScore" />
            <MacroConfidenceCard Confidence="_snapshot?.Confidence ?? 0" MacroScore="_snapshot?.MacroScore" />
            <MacroRegimeCard Snapshot="_snapshot" />
            <MacroHeatMap Snapshot="_snapshot" />
            <MacroRecommendationCard Recommendations="_snapshot?.Recommendations" />
            <MacroIndicatorGrid Indicators="_snapshot?.Indicators" />
            <MacroEventTimeline Events="_snapshot?.UpcomingEvents" MaxItems="8" />
            <MacroProviderStatus Providers="_providers" />
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "symbol")]
    public string? SymbolQuery { get; set; }

    private string _symbol = "MNQ";
    private MacroSnapshotModel? _snapshot;
    private List<MacroProviderStatusModel>? _providers;
    private bool _loading;
    private bool _hubConnected;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        SignIn.HydrateSession(Session);
        if (!string.IsNullOrWhiteSpace(SymbolQuery))
            _symbol = SymbolQuery.ToUpperInvariant();

        MacroHub.SnapshotUpdated += OnSnapshotUpdated;
        MacroHub.ProvidersUpdated += OnProvidersUpdated;

        try
        {
            await MacroHub.ConnectAsync();
            _hubConnected = MacroHub.IsConnected;
        }
        catch
        {
            _hubConnected = false;
        }

        await LoadAsync();
    }

    private async Task OnSymbolChangedAsync()
    {
        var uri = Nav.GetUriWithQueryParameter("symbol", _symbol);
        Nav.NavigateTo(uri, replace: true);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _snapshot = await MacroApi.GetCurrentAsync(_symbol);
            _providers = await MacroApi.GetProvidersAsync();
            if (_snapshot is null)
                _error = "Snapshot macro indisponível.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnSnapshotUpdated(MacroSnapshotModel snapshot)
    {
        _snapshot = snapshot;
        _hubConnected = true;
        InvokeAsync(StateHasChanged);
    }

    private void OnProvidersUpdated(List<MacroProviderStatusModel> providers)
    {
        _providers = providers;
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        MacroHub.SnapshotUpdated -= OnSnapshotUpdated;
        MacroHub.ProvidersUpdated -= OnProvidersUpdated;
        await MacroHub.DisposeAsync();
    }
}

<style>
    .macro-page-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1rem;
    }
</style>
