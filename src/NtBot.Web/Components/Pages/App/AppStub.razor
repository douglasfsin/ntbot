@page "/app/scalping"
@page "/app/grid"
@page "/app/positions"
@page "/app/risk"
@page "/app/signals"
@page "/app/trades"
@layout AppLayout
@rendermode InteractiveServer

<PageTitle>@PageTitleText — NTBot</PageTitle>

<div class="app-page">
    <h1>@PageTitleText</h1>
    <div class="nt-card">
        <p class="app-muted" style="margin:0 0 1rem;">
            Módulo em migração do React para Blazor (Fase 6).
            Prioridade concluída: Quant, ProfitChart, Wyckoff, Macro e Settings.
        </p>
        <p style="margin:0;font-size:0.875rem;">
            API disponível em <code>src/NtBot.Api</code> — use o dashboard React em
            <code>ntbot-dashboard/</code> até esta tela ser portada.
        </p>
    </div>
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private string PageTitleText => Navigation.Uri.Split('/', StringSplitOptions.RemoveEmptyEntries).LastOrDefault() switch
    {
        "scalping" => "Scalping",
        "grid" => "Grid Manager",
        "positions" => "Positions",
        "risk" => "Risk Management",
        "signals" => "Sinais",
        "trades" => "Trades",
        _ => "App"
    };
}
