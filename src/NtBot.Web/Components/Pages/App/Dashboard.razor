@page "/app"
@layout AppLayout
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject MacroApiClient MacroApi
@inject MacroHubService MacroHub
@inject MarketApiClient MarketApi
@inject MarketHubService MarketHub
@inject MarketDriversApiClient DriversApi
@inject MarketDriversHubService DriversHub
@inject TradingIntelligenceApiClient TiApi
@inject TradingIntelligenceHubService TiHub
@inject AuthSession Session
@inject AuthSignInService SignIn
@inject BillingApiClient BillingApi

<PageTitle>Dashboard — NTBot</PageTitle>

<div class="app-page">
    <header class="app-page-header">
        <div>
            <h1>Dashboard</h1>
            <p class="app-page-sub">
                @if (Session.Tenant is not null)
                {
                    <span>@Session.Tenant.Name · Plano @Session.Tenant.Plan</span>
                }
            </p>
        </div>
        <div class="app-page-actions">
            @if (_hubConnected)
            {
                <span class="nt-badge nt-badge-success">Macro live</span>
            }
            @if (_marketHubConnected)
            {
                <span class="nt-badge nt-badge-success">Market live</span>
            }
            @if (_driversHubConnected)
            {
                <span class="nt-badge nt-badge-success">Drivers live</span>
            }
            @if (_tiHubConnected)
            {
                <span class="nt-badge nt-badge-success">TI live</span>
            }
            <a href="/app/macro" class="nt-btn nt-btn-secondary" style="text-decoration:none;">Macro completo</a>
            <a href="/app/market" class="nt-btn nt-btn-secondary" style="text-decoration:none;">Market completo</a>
            <a href="/app/drivers" class="nt-btn nt-btn-secondary" style="text-decoration:none;">Drivers</a>
        </div>
    </header>

    @if (_loading)
    {
        <p class="app-muted">Carregando macro intelligence...</p>
    }
    else
    {
        <h2 style="font-size:1rem;margin:0 0 0.75rem;">Macro Intelligence</h2>
        @if (_macroError is not null)
        {
            <div class="nt-card app-error" style="margin-bottom:1rem;">@_macroError</div>
        }
        <MacroQuickView Snapshot="@_snapshot" />

        <h2 style="font-size:1rem;margin:1.5rem 0 0.75rem;">Market Overview</h2>
        @if (_marketError is not null)
        {
            <div class="nt-card app-error" style="margin-bottom:1rem;">@_marketError</div>
        }
        else if (_marketOverview is not null)
        {
            <MarketQuickView Overview="@_marketOverview" />
        }
        else
        {
            <p class="app-muted">Market intelligence indisponível.</p>
        }

        <h2 style="font-size:1rem;margin:1.5rem 0 0.75rem;">Market Drivers</h2>
        @if (_driversDashboard?.Count > 0)
        {
            <div class="md-grid">
                @foreach (var item in _driversDashboard.Take(3))
                {
                    <MarketDriversQuickView Item="item" />
                }
            </div>
            <p style="margin-top:0.75rem;"><a href="/app/drivers" class="app-muted">Ver todos os drivers →</a></p>
        }
        else
        {
            <p class="app-muted">Market drivers indisponível.</p>
        }

        <h2 style="font-size:1rem;margin:1.5rem 0 0.75rem;">Trading Intelligence</h2>
        @if (_tiDashboard?.Count > 0)
        {
            <div class="ti-dash-grid">
                @foreach (var item in _tiDashboard)
                {
                    <TradingIntelligenceQuickView Item="item" />
                }
            </div>
            <p style="margin-top:0.75rem;"><a href="/app/drivers" class="app-muted">Abrir workspace TI →</a></p>
        }
        else
        {
            <p class="app-muted">Trading intelligence indisponível.</p>
        }

        <h2 style="font-size:1rem;margin:1.5rem 0 0.75rem;">Módulos</h2>
        <div class="app-module-grid">
            @foreach (var module in _modules)
            {
                <a href="@module.Href" class="nt-card app-module-card">
                    <strong>@module.Title</strong>
                    <span class="app-muted">@module.Description</span>
                    <span class="nt-badge @module.BadgeClass">@module.Status</span>
                </a>
            }
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private bool _hubConnected;
    private bool _marketHubConnected;
    private bool _driversHubConnected;
    private bool _tiHubConnected;
    private MacroSnapshotModel? _snapshot;
    private MarketOverviewModel? _marketOverview;
    private List<MarketDriversDashboardItemModel>? _driversDashboard;
    private List<TradingIntelligenceDashboardItemModel>? _tiDashboard;
    private string? _macroError;
    private string? _marketError;
    private SubscriptionModel? _subscription;

    private readonly ModuleLink[] _modules =
    [
        new("/app/macro", "Macro Intelligence", "Regime, FRED e calendário", "Pronto", "nt-badge-success"),
        new("/app/quant", "Quant Strategy", "GEX, correlação e sinais", "Pronto", "nt-badge-success"),
        new("/app/macro/calendar", "Economic Calendar", "Eventos de alto impacto", "Pronto", "nt-badge-success"),
        new("/app/macro/market", "Market Overview", "Heat map e indicadores", "Pronto", "nt-badge-success"),
        new("/app/market", "Market Intelligence", "Yahoo Finance · Commodities", "Pronto", "nt-badge-success"),
        new("/app/drivers", "Trading Intelligence", "Confluence · Zonas · Agentes IA", "Pronto", "nt-badge-success"),
        new("/app/settings", "Configurações", "Conta e billing", "Pronto", "nt-badge-success"),
    ];

    protected override async Task OnInitializedAsync()
    {
        SignIn.HydrateSession(Session);
        MacroHub.SnapshotUpdated += OnSnapshotUpdated;
        MarketHub.OverviewUpdated += OnMarketOverviewUpdated;
        DriversHub.DashboardUpdated += OnDriversDashboardUpdated;
        TiHub.SnapshotUpdated += OnTiSnapshotUpdated;

        try
        {
            _subscription = await BillingApi.GetSubscriptionAsync();
            _snapshot = await MacroApi.GetCurrentAsync();
            if (_snapshot is null)
                _macroError = "Snapshot macro indisponível.";

            _marketOverview = await MarketApi.GetOverviewAsync();
            if (_marketOverview is null)
                _marketError = "Market intelligence indisponível.";

            _driversDashboard = await DriversApi.GetDashboardAsync();
            _tiDashboard = await TiApi.GetDashboardAsync();
        }
        catch (Exception ex)
        {
            _macroError ??= ex.Message;
        }

        try
        {
            await MacroHub.ConnectAsync();
            _hubConnected = MacroHub.IsConnected;
        }
        catch
        {
            _hubConnected = false;
        }

        try
        {
            await MarketHub.ConnectAsync();
            _marketHubConnected = MarketHub.IsConnected;
        }
        catch
        {
            _marketHubConnected = false;
        }

        try
        {
            await DriversHub.ConnectAsync();
            _driversHubConnected = DriversHub.IsConnected;
        }
        catch
        {
            _driversHubConnected = false;
        }

        try
        {
            await TiHub.ConnectAsync();
            _tiHubConnected = TiHub.IsConnected;
        }
        catch
        {
            _tiHubConnected = false;
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnDriversDashboardUpdated(List<MarketDriversDashboardItemModel> items)
    {
        _driversDashboard = items;
        _driversHubConnected = true;
        InvokeAsync(StateHasChanged);
    }

    private void OnMarketOverviewUpdated(MarketOverviewModel overview)
    {
        _marketOverview = overview;
        _marketError = null;
        _marketHubConnected = true;
        InvokeAsync(StateHasChanged);
    }

    private void OnSnapshotUpdated(MacroSnapshotModel snapshot)
    {
        _snapshot = snapshot;
        _macroError = null;
        _hubConnected = true;
        InvokeAsync(StateHasChanged);
    }

    private void OnTiSnapshotUpdated(TradingIntelligenceSnapshotModel snapshot)
    {
        if (_tiDashboard is null) return;
        var idx = _tiDashboard.FindIndex(i => string.Equals(i.Asset, snapshot.Asset, StringComparison.OrdinalIgnoreCase));
        if (idx < 0) return;

        var topIntersection = snapshot.Intersections
            .Where(i => i.HighConfluence)
            .OrderByDescending(i => i.ConfluenceScore)
            .FirstOrDefault();

        _tiDashboard[idx] = new TradingIntelligenceDashboardItemModel
        {
            Asset = snapshot.Asset,
            ConfluenceScore = snapshot.Confluence.Score,
            Classification = snapshot.Confluence.Classification,
            Recommendation = snapshot.Confluence.Recommendation,
            Confidence = snapshot.Confluence.Confidence,
            HighConfluenceZones = snapshot.Intersections.Count(i => i.HighConfluence),
            AgentInsightCount = snapshot.AgentInsights.Count,
            TopIntersection = topIntersection?.Pair ?? string.Empty,
            ExplanationPreview = snapshot.Confluence.Explanation.Length > 120
                ? snapshot.Confluence.Explanation[..117] + "..."
                : snapshot.Confluence.Explanation
        };
        _tiHubConnected = true;
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        MacroHub.SnapshotUpdated -= OnSnapshotUpdated;
        MarketHub.OverviewUpdated -= OnMarketOverviewUpdated;
        DriversHub.DashboardUpdated -= OnDriversDashboardUpdated;
        TiHub.SnapshotUpdated -= OnTiSnapshotUpdated;
        await MacroHub.DisposeAsync();
        await MarketHub.DisposeAsync();
        await DriversHub.DisposeAsync();
        await TiHub.DisposeAsync();
    }

    private record ModuleLink(string Href, string Title, string Description, string Status, string BadgeClass);
}
