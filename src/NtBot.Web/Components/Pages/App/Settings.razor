@page "/app/settings"
@layout AppLayout
@rendermode InteractiveServer
@inject AuthSession Session
@inject BillingApiClient BillingApi
@inject ConnectorApiClient ConnectorApi
@inject MacroApiClient MacroApi
@inject AuthSignInService SignIn
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Configurações — NTBot</PageTitle>

<div class="app-page">
    <header class="app-page-header">
        <div>
            <h1>Configurações</h1>
            <p class="app-page-sub">Conta, tenant, assinatura e Connector Windows</p>
        </div>
    </header>

    <div class="app-settings-grid">
        <div class="nt-card">
            <h2 style="margin:0 0 1rem;font-size:1rem;">Conta</h2>
            @if (Session.User is not null)
            {
                <dl class="app-dl">
                    <dt>Nome</dt><dd>@(Session.User.FullName ?? "—")</dd>
                    <dt>Email</dt><dd>@Session.User.Email</dd>
                    <dt>Perfil</dt><dd>@Session.User.Role</dd>
                </dl>
            }
        </div>

        <div class="nt-card">
            <h2 style="margin:0 0 1rem;font-size:1rem;">Tenant</h2>
            @if (Session.Tenant is not null)
            {
                <dl class="app-dl">
                    <dt>Organização</dt><dd>@Session.Tenant.Name</dd>
                    <dt>Plano</dt><dd><span class="nt-badge nt-badge-success">@Session.Tenant.Plan</span></dd>
                    <dt>Trial</dt><dd>@(Session.Tenant.IsTrial ? "Sim" : "Não")</dd>
                </dl>
            }
        </div>

        <div class="nt-card">
            <h2 style="margin:0 0 1rem;font-size:1rem;">Assinatura Stripe</h2>
            @if (_loadingSub)
            {
                <p class="app-muted">Carregando...</p>
            }
            else if (_subscription is not null)
            {
                <dl class="app-dl">
                    <dt>Plano</dt><dd>@_subscription.PlanName</dd>
                    <dt>Status</dt><dd>@_subscription.Status / @_subscription.PaymentStatus</dd>
                    <dt>Valor</dt><dd>$@_subscription.MonthlyPrice.ToString("F0")/mo</dd>
                </dl>
            }
            else
            {
                <p class="app-muted" style="margin:0 0 1rem;">Nenhuma assinatura paga ativa.</p>
                <a href="/pricing" class="nt-btn nt-btn-primary" style="text-decoration:none;">Ver planos</a>
            }
        </div>

        <div class="nt-card">
            <h2 style="margin:0 0 1rem;font-size:1rem;">Billing Stripe</h2>
            @if (_billingConfig?.StripeConfigured == true)
            {
                <p class="app-muted" style="margin:0;">
                    Pagamentos @(_billingConfig.TestMode ? "test mode" : "live") habilitados.
                </p>
            }
            else
            {
                <p class="app-muted" style="margin:0;">Stripe não configurado no ambiente da API.</p>
            }
        </div>

        <div class="nt-card" style="grid-column:1/-1;">
            <h2 style="margin:0 0 1rem;font-size:1rem;">Macro Intelligence</h2>
            @if (_loadingMacro)
            {
                <p class="app-muted">Carregando providers...</p>
            }
            else if (_macroProviders is null || _macroProviders.Count == 0)
            {
                <p class="app-muted" style="margin:0;">Nenhum provider macro configurado.</p>
            }
            else
            {
                @foreach (var provider in _macroProviders.OrderBy(p => p.Priority))
                {
                    <div class="macro-settings-row">
                        <div>
                            <strong>@provider.Name</strong>
                            <div class="app-muted" style="font-size:0.8rem;">
                                Prioridade @provider.Priority · Refresh @provider.RefreshIntervalMinutes min
                                · @MacroDisplay.Health(provider.HealthStatus)
                            </div>
                            @if (_configuringProviderId == provider.Id)
                            {
                                <div style="margin-top:0.5rem;display:grid;gap:0.5rem;max-width:420px;">
                                    <input class="app-select" placeholder="API URL (opcional)" @bind="_configureApiUrl" />
                                    <input class="app-select" type="password" placeholder="API Key (opcional)" @bind="_configureApiKey" />
                                    <input class="app-select" type="number" placeholder="Refresh (min)" @bind="_configureRefresh" />
                                    <div style="display:flex;gap:0.5rem;">
                                        <button type="button" class="nt-btn nt-btn-primary" disabled="@_savingMacro" @onclick="() => SaveProviderConfigAsync(provider.Id)">Salvar</button>
                                        <button type="button" class="nt-btn nt-btn-secondary" @onclick="CancelConfigure">Cancelar</button>
                                    </div>
                                </div>
                            }
                        </div>
                        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;">
                            <span class="nt-badge @MacroDisplay.HealthBadgeClass(provider.HealthStatus)">
                                @(provider.Enabled ? "Ativo" : "Desativado")
                            </span>
                            @if (provider.Enabled)
                            {
                                <button type="button" class="nt-btn nt-btn-secondary" disabled="@_savingMacro" @onclick="() => DisableProviderAsync(provider.Id)">Desativar</button>
                            }
                            else
                            {
                                <button type="button" class="nt-btn nt-btn-primary" disabled="@_savingMacro" @onclick="() => EnableProviderAsync(provider.Id)">Ativar</button>
                            }
                            <button type="button" class="nt-btn nt-btn-secondary" @onclick="() => StartConfigure(provider)">Configurar</button>
                        </div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(_macroMessage))
                {
                    <p class="app-muted" style="margin:1rem 0 0;">@_macroMessage</p>
                }
            }
        </div>

        <div class="nt-card" style="grid-column:1/-1;">
            <h2 style="margin:0 0 1rem;font-size:1rem;">Connector Windows</h2>
            @if (_loadingConnector)
            {
                <p class="app-muted">Carregando...</p>
            }
            else if (_connector is not null)
            {
                <dl class="app-dl">
                    <dt>Status</dt>
                    <dd>
                        @if (_connector.IsConnected)
                        {
                            <span class="nt-badge nt-badge-success">Conectado</span>
                        }
                        else
                        {
                            <span class="nt-badge">Desconectado</span>
                        }
                    </dd>
                    <dt>Api Key</dt>
                    <dd>
                        @if (!string.IsNullOrEmpty(_revealedApiKey))
                        {
                            <code style="word-break:break-all;">@_revealedApiKey</code>
                            <button type="button" class="nt-btn nt-btn-secondary" style="margin-left:0.5rem;" @onclick="CopyApiKeyAsync">Copiar</button>
                        }
                        else if (_connector.HasActiveKey)
                        {
                            <span>@(_connector.KeyPrefix)…</span>
                        }
                        else
                        {
                            <span class="app-muted">Nenhuma chave ativa</span>
                        }
                    </dd>
                    <dt>Plano</dt><dd>@_connector.Plan</dd>
                    <dt>Licença</dt><dd>@(_connector.LicenseActive ? "Ativa" : "Inativa")</dd>
                    <dt>Expiração da chave</dt><dd>@FormatDate(_connector.KeyExpiresAt)</dd>
                    <dt>Última conexão</dt><dd>@FormatDate(_connector.LastConnectionAt)</dd>
                    <dt>Versão conectada</dt><dd>@(_connector.ConnectedVersion ?? "—")</dd>
                    <dt>Último uso / IP</dt><dd>@FormatDate(_connector.LastUsedAt) @(_connector.LastUsedIp is not null ? $"({_connector.LastUsedIp})" : "")</dd>
                    <dt>Download</dt>
                    <dd>
                        @if (!string.IsNullOrEmpty(_connector.LatestVersion))
                        {
                            <span>v@_connector.LatestVersion</span>
                            @if (_connector.DownloadSizeBytes > 0)
                            {
                                <span class="app-muted"> (@FormatSize(_connector.DownloadSizeBytes))</span>
                            }
                        }
                        else
                        {
                            <span class="app-muted">Indisponível</span>
                        }
                    </dd>
                </dl>

                @if (!string.IsNullOrWhiteSpace(_connector.ReleaseNotes))
                {
                    <details style="margin-top:1rem;">
                        <summary>Release Notes</summary>
                        <p class="app-muted" style="white-space:pre-wrap;margin:0.5rem 0 0;">@_connector.ReleaseNotes</p>
                    </details>
                }

                <div style="margin-top:1rem;display:flex;gap:0.5rem;flex-wrap:wrap;">
                    @if (!_connector.HasActiveKey || !string.IsNullOrEmpty(_revealedApiKey))
                    {
                        <button type="button" class="nt-btn nt-btn-primary" disabled="@_generatingKey" @onclick="GenerateKeyAsync">
                            @(_connector.HasActiveKey ? "Rotacionar chave" : "Gerar Api Key")
                        </button>
                    }
                    else
                    {
                        <button type="button" class="nt-btn nt-btn-secondary" disabled="@_generatingKey" @onclick="GenerateKeyAsync">Rotacionar chave</button>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_connectorMessage))
                {
                    <p class="app-muted" style="margin:1rem 0 0;">@_connectorMessage</p>
                }
            }
            else
            {
                <p class="app-muted" style="margin:0 0 1rem;">
                    @(_connectorError ?? "Não foi possível carregar o status do connector.")
                </p>
                <button type="button" class="nt-btn nt-btn-primary" disabled="@_generatingKey" @onclick="GenerateKeyAsync">
                    Gerar Api Key
                </button>
                @if (!string.IsNullOrEmpty(_connectorMessage))
                {
                    <p class="app-muted" style="margin:1rem 0 0;">@_connectorMessage</p>
                }
            }
        </div>
    </div>
</div>

<style>
    .macro-settings-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        padding: 0.75rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .macro-settings-row:last-child { border-bottom: none; }
</style>

@code {
    private SubscriptionModel? _subscription;
    private BillingConfigModel? _billingConfig;
    private ConnectorStatusModel? _connector;
    private string? _connectorError;
    private string? _revealedApiKey;
    private string? _connectorMessage;
    private bool _loadingSub = true;
    private bool _loadingConnector = true;
    private bool _generatingKey;
    private bool _loadingMacro = true;
    private bool _savingMacro;
    private List<MacroProviderStatusModel>? _macroProviders;
    private Guid? _configuringProviderId;
    private string? _configureApiUrl;
    private string? _configureApiKey;
    private int? _configureRefresh;
    private string? _macroMessage;

    protected override async Task OnInitializedAsync()
    {
        SignIn.HydrateSession(Session);

        try
        {
            _billingConfig = await BillingApi.GetConfigAsync();
            _subscription = await BillingApi.GetSubscriptionAsync();
        }
        catch
        {
            // optional endpoints
        }
        finally
        {
            _loadingSub = false;
        }

        await LoadConnectorAsync();
        await LoadMacroProvidersAsync();
    }

    private async Task LoadMacroProvidersAsync()
    {
        _loadingMacro = true;
        try
        {
            _macroProviders = await MacroApi.GetProvidersAsync();
        }
        catch (Exception ex)
        {
            _macroMessage = ex.Message;
        }
        finally
        {
            _loadingMacro = false;
        }
    }

    private async Task EnableProviderAsync(Guid id)
    {
        _savingMacro = true;
        _macroMessage = null;
        try
        {
            await MacroApi.EnableProviderAsync(id);
            _macroMessage = "Provider ativado.";
            await LoadMacroProvidersAsync();
        }
        catch (Exception ex)
        {
            _macroMessage = ex.Message;
        }
        finally
        {
            _savingMacro = false;
        }
    }

    private async Task DisableProviderAsync(Guid id)
    {
        _savingMacro = true;
        _macroMessage = null;
        try
        {
            await MacroApi.DisableProviderAsync(id);
            _macroMessage = "Provider desativado.";
            await LoadMacroProvidersAsync();
        }
        catch (Exception ex)
        {
            _macroMessage = ex.Message;
        }
        finally
        {
            _savingMacro = false;
        }
    }

    private void StartConfigure(MacroProviderStatusModel provider)
    {
        _configuringProviderId = provider.Id;
        _configureApiUrl = provider.ApiUrl;
        _configureApiKey = null;
        _configureRefresh = provider.RefreshIntervalMinutes;
    }

    private void CancelConfigure()
    {
        _configuringProviderId = null;
        _configureApiKey = null;
    }

    private async Task SaveProviderConfigAsync(Guid id)
    {
        _savingMacro = true;
        _macroMessage = null;
        try
        {
            await MacroApi.ConfigureProviderAsync(id, new MacroProviderConfigureModel
            {
                ApiUrl = string.IsNullOrWhiteSpace(_configureApiUrl) ? null : _configureApiUrl,
                ApiKey = string.IsNullOrWhiteSpace(_configureApiKey) ? null : _configureApiKey,
                RefreshIntervalMinutes = _configureRefresh
            });
            _macroMessage = "Provider configurado.";
            _configuringProviderId = null;
            _configureApiKey = null;
            await LoadMacroProvidersAsync();
        }
        catch (Exception ex)
        {
            _macroMessage = ex.Message;
        }
        finally
        {
            _savingMacro = false;
        }
    }

    private async Task LoadConnectorAsync()
    {
        _loadingConnector = true;
        _connectorError = null;
        try
        {
            var (status, error) = await ConnectorApi.GetStatusAsync();
            _connector = status;
            _connectorError = error;
        }
        catch (Exception ex)
        {
            _connector = null;
            _connectorError = ex.Message;
        }
        finally
        {
            _loadingConnector = false;
        }
    }

    private async Task GenerateKeyAsync()
    {
        _generatingKey = true;
        _connectorMessage = null;
        try
        {
            var result = await ConnectorApi.GenerateKeyAsync();
            if (result != null)
            {
                _revealedApiKey = result.ApiKey;
                _connectorMessage = result.Message;
                await LoadConnectorAsync();
            }
        }
        catch (Exception ex)
        {
            _connectorMessage = ex.Message;
        }
        finally
        {
            _generatingKey = false;
        }
    }

    private async Task CopyApiKeyAsync()
    {
        if (string.IsNullOrEmpty(_revealedApiKey)) return;

        try
        {
            var copied = await JS.InvokeAsync<bool>("ntbot.copyText", _revealedApiKey);
            _connectorMessage = copied
                ? "Api Key copiada."
                : "Não foi possível copiar automaticamente. Selecione o texto e use Ctrl+C.";
        }
        catch
        {
            _connectorMessage = "Não foi possível copiar automaticamente. Selecione o texto e use Ctrl+C.";
        }
    }

    private static string FormatDate(DateTime? value) =>
        value.HasValue ? value.Value.ToLocalTime().ToString("g") : "—";

    private static string FormatSize(long? bytes) =>
        bytes switch
        {
            null or <= 0 => "—",
            < 1024 => $"{bytes} B",
            < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
            _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
        };
}
