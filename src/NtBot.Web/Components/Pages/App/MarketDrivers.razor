@page "/app/drivers"
@page "/app/drivers/{Symbol}"
@layout AppLayout
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject MarketDriversApiClient DriversApi
@inject MarketDriversHubService DriversHub
@inject TradingIntelligenceApiClient TiApi
@inject TradingIntelligenceHubService TiHub
@inject AuthSignInService SignIn
@inject AuthSession Session
@inject NavigationManager Nav
@inject ConnectorWebHubService ConnectorHub
@inject ProfitChartApiClient ProfitApi

<PageTitle>Trading Intelligence — NTBot</PageTitle>

<div class="app-page md-page ti-workspace">
    <header class="app-page-header">
        <div>
            <h1>Trading Intelligence</h1>
            <p class="app-page-sub">Market Drivers · Confluence · Zonas operacionais</p>
        </div>
        <div class="app-page-actions ti-action-bar">
            @if (_hubConnected || _tiHubConnected) { <span class="nt-badge nt-badge-success">Live</span> }
            @if (_n8nLive)
            {
                <span class="nt-badge nt-badge-success" title="n8n configurado">IA n8n</span>
            }
            <div class="ti-symbol-picker">
                <select class="app-select" @bind="_symbol" @bind:after="OnSymbolChangedAsync">
                    @foreach (var sym in _symbols)
                    {
                        <option value="@sym">@FormatTickerOption(sym)</option>
                    }
                </select>
                @if (ResolveLivePrice(_symbol) is decimal livePrice)
                {
                    <span class="ti-symbol-price" title="Preço live via connector">@LivePriceResolver.FormatPrice(_symbol, livePrice)</span>
                }
            </div>
            <button type="button" class="nt-btn nt-btn-primary" @onclick="LoadAsync" disabled="@_loading">Atualizar</button>
            <button type="button"
                    class="nt-btn nt-btn-accent ti-refresh-ia-btn"
                    @onclick="RefreshTiAsync"
                    disabled="@_loading || _refreshing"
                    title="Invalida cache e reconsulta agentes n8n">
                @(_refreshing ? "IA…" : "Atualizar IA")
            </button>
        </div>
    </header>

    @if (_loading && _snapshot is null && _tiSnapshot is null)
    {
        <p class="app-muted">Carregando workspace...</p>
    }
    else if (_error is not null)
    {
        <div class="nt-card app-error">@_error</div>
    }
    else
    {
        <div class="ti-workspace-grid">
            <div class="ti-main">
                <TradingIntelligenceChart Symbol="_symbol"
                                          Timeframes="_tiSnapshot?.TimeframeAnalyses ?? []"
                                          Intersections="_tiSnapshot?.Intersections ?? []"
                                          Zones="_tiSnapshot?.OperationalZones ?? []" />
                @if (_tiSnapshot is not null || _snapshot is not null)
                {
                    <div class="ti-top-row">
                        @if (_tiSnapshot is not null)
                        {
                            <ConfluenceCard Confluence="_tiSnapshot.Confluence" />
                        }
                        @if (_snapshot is not null)
                        {
                            <MarketDriversSummary Snapshot="_snapshot" />
                        }
                    </div>
                }
                @if (_snapshot is not null)
                {
                    <MarketDriversExplanation Explanation="@_snapshot.Explanation" AiSummary="@_snapshot.AiSummary" Compact="true" />
                    <div class="ti-mid-row">
                        <div class="nt-card md-card md-drivers-list">
                            <h3 class="md-section-title">Drivers</h3>
                            <TiExpandableSection @bind-Expanded="_driversExpanded" BodyClass="ti-scroll-panel">
                                <MarketDriversList Drivers="_snapshot.Drivers" Bare="true" />
                            </TiExpandableSection>
                        </div>
                        @if (_tiSnapshot is not null)
                        {
                            <OperationalZonesPanel Zones="_tiSnapshot.OperationalZones" />
                        }
                    </div>
                }
                else if (_tiSnapshot is not null)
                {
                    <OperationalZonesPanel Zones="_tiSnapshot.OperationalZones" />
                }
                @if (_snapshot is not null)
                {
                    <div class="ti-bottom-row">
                        <section class="nt-card md-card">
                            <h3 class="md-section-title">Timeline</h3>
                            <div class="ti-scroll-panel-sm">
                                <MarketDriversTimeline Drivers="_snapshot.Drivers" MaxItems="6" />
                            </div>
                        </section>
                    </div>
                }
                @if (_snapshot is not null)
                {
                    <div class="nt-card md-card">
                        <h3 class="md-section-title">HeatMap — Drivers</h3>
                        <MarketDriversHeatMap Cells="_snapshot.HeatMap" />
                    </div>
                }
            </div>
            <aside class="ti-side">
                @if (_tiSnapshot is not null)
                {
                    <TradingIntelligenceHeatMap Cells="_tiSnapshot.HeatMap" />
                    <div class="ti-scroll-panel">
                        <AiWorkspacePanel Summary="_tiSnapshot.AiSummary"
                                          Symbol="_symbol"
                                          N8nLive="_n8nLive"
                                          OnRefreshed="LoadAsync" />
                    </div>
                    <AgentInsightsPanel Insights="_tiSnapshot.AgentInsights" />
                }
            </aside>
        </div>
    }
</div>

<style>
    .ti-symbol-picker {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    .ti-symbol-price {
        font-size: 1.05rem;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
        color: var(--nt-accent, #3b82f6);
        white-space: nowrap;
    }
</style>

@code {
    [Parameter] public string? Symbol { get; set; }

    private string _symbol = "WIN";
    private readonly string[] _symbols = ["WIN", "WDO", "PETR4", "VALE3", "XAUUSD", "SP500", "NASDAQ", "BTCUSD"];
    private MarketDriversSnapshotModel? _snapshot;
    private TradingIntelligenceSnapshotModel? _tiSnapshot;
    private bool _loading;
    private bool _hubConnected;
    private bool _tiHubConnected;
    private bool _driversExpanded;
    private bool _refreshing;
    private bool _n8nLive;
    private string? _error;
    private readonly Dictionary<string, decimal> _livePrices = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        SignIn.HydrateSession(Session);
        if (!string.IsNullOrWhiteSpace(Symbol))
            _symbol = Symbol.ToUpperInvariant();

        DriversHub.SnapshotUpdated += OnSnapshotUpdated;
        TiHub.SnapshotUpdated += OnTiSnapshotUpdated;
        ConnectorHub.TickReceived += OnConnectorTick;
        ConnectorHub.Mt5ForexUpdated += OnMt5ForexUpdated;

        try
        {
            await DriversHub.ConnectAsync();
            _hubConnected = DriversHub.IsConnected;
            await TiHub.ConnectAsync();
            _tiHubConnected = TiHub.IsConnected;
            await ConnectorHub.ConnectAsync();
        }
        catch { /* hubs optional */ }

        await LoadLivePricesAsync();
        await LoadAsync();
    }

    private async Task LoadLivePricesAsync()
    {
        try
        {
            var tickers = await ProfitApi.GetAllTickersAsync();
            foreach (var (key, status) in tickers)
            {
                if (status.LastPrice is > 0)
                    LivePriceResolver.ApplyTick(_livePrices, key, status.LastPrice, null, null);
            }
        }
        catch { /* optional */ }
    }

    private decimal? ResolveLivePrice(string symbol) =>
        LivePriceResolver.ResolvePrice(_livePrices, symbol);

    private string FormatTickerOption(string sym)
    {
        var price = ResolveLivePrice(sym);
        return price is null ? sym : $"{sym}  {LivePriceResolver.FormatPrice(sym, price.Value)}";
    }

    private void OnConnectorTick(ConnectorTickUpdate tick) =>
        ApplyLiveTick(tick.Symbol, tick.Last, tick.Bid, tick.Ask);

    private void OnMt5ForexUpdated(Mt5ForexUpdateModel update)
    {
        foreach (var c in update.Currencies)
            LivePriceResolver.ApplyTick(_livePrices, c.Symbol, c.Price, null, null);
        InvokeAsync(StateHasChanged);
    }

    private void ApplyLiveTick(string symbol, decimal? last, decimal? bid, decimal? ask)
    {
        LivePriceResolver.ApplyTick(_livePrices, symbol, last, bid, ask);
        InvokeAsync(StateHasChanged);
    }

    private async Task OnSymbolChangedAsync()
    {
        Nav.NavigateTo($"/app/drivers/{_symbol}", replace: true);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _snapshot = await DriversApi.GetSnapshotAsync(_symbol);
            _tiSnapshot = await TiApi.GetSnapshotAsync(_symbol);
            var status = await TiApi.GetStatusAsync();
            _n8nLive = status?.N8nConfigured == true;
            if (_snapshot is null && _tiSnapshot is null)
                _error = $"Dados indisponíveis para {_symbol}.";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task RefreshTiAsync()
    {
        _refreshing = true;
        _error = null;
        try
        {
            if (await TiApi.RefreshAsync(_symbol))
                await LoadAsync();
            else
                _error = "Falha ao forçar refresh IA.";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _refreshing = false; }
    }

    private void OnSnapshotUpdated(MarketDriversSnapshotModel snapshot)
    {
        if (!string.Equals(snapshot.Asset, _symbol, StringComparison.OrdinalIgnoreCase)) return;
        _snapshot = snapshot;
        _hubConnected = true;
        InvokeAsync(StateHasChanged);
    }

    private void OnTiSnapshotUpdated(TradingIntelligenceSnapshotModel snapshot)
    {
        if (!string.Equals(snapshot.Asset, _symbol, StringComparison.OrdinalIgnoreCase)) return;
        _tiSnapshot = snapshot;
        _tiHubConnected = true;
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        DriversHub.SnapshotUpdated -= OnSnapshotUpdated;
        TiHub.SnapshotUpdated -= OnTiSnapshotUpdated;
        ConnectorHub.TickReceived -= OnConnectorTick;
        ConnectorHub.Mt5ForexUpdated -= OnMt5ForexUpdated;
        await ConnectorHub.DisposeAsync();
        await DriversHub.DisposeAsync();
        await TiHub.DisposeAsync();
    }
}
