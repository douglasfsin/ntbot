@namespace NtBot.Web.Components.Macro

<div class="nt-card macro-card">
    <h3 class="macro-card-title">Próximos Eventos</h3>
    @if (Events is null || Events.Count == 0)
    {
        <p class="app-muted">Nenhum evento econômico próximo.</p>
    }
    else
    {
        <div class="macro-timeline">
            @foreach (var ev in Events.OrderBy(e => e.EventTime).Take(MaxItems))
            {
                <div class="macro-event">
                    <div class="macro-event-time">@ev.EventTime.ToLocalTime().ToString("dd/MM HH:mm")</div>
                    <div>
                        <strong>@ev.EventName</strong>
                        <div class="app-muted" style="font-size:0.8rem;">@ev.Country · @ev.Currency · @ev.Impact</div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public List<MacroCalendarEventModel>? Events { get; set; }
    [Parameter] public int MaxItems { get; set; } = 10;
}

<style>
    .macro-timeline { display: grid; gap: 0.65rem; }
    .macro-event { display: grid; grid-template-columns: 90px 1fr; gap: 0.75rem; align-items: start; }
    .macro-event-time { font-size: 0.8rem; color: #94a3b8; }
</style>
