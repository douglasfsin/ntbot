@namespace NtBot.Web.Components.Macro

<div class="nt-card macro-card">
    <h3 class="macro-card-title">Heat Map Macro</h3>
    @if (Snapshot is null)
    {
        <p class="app-muted">—</p>
    }
    else
    {
        <div class="macro-heatmap">
            @foreach (var cell in Cells)
            {
                <div class="macro-heat-cell @HeatClass(cell.Level)">
                    <span>@cell.Label</span>
                    <strong>@cell.Display</strong>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public MacroSnapshotModel? Snapshot { get; set; }

    private IEnumerable<(string Label, string Level, string Display)> Cells =>
        Snapshot is null ? [] :
        [
            ("Liquidez", Snapshot.Liquidity, MacroDisplay.Level(Snapshot.Liquidity)),
            ("Dólar", Snapshot.DollarStrength, MacroDisplay.Dollar(Snapshot.DollarStrength)),
            ("Volatilidade", Snapshot.Volatility, MacroDisplay.Volatility(Snapshot.Volatility)),
            ("Juros", Snapshot.InterestRate, MacroDisplay.Interest(Snapshot.InterestRate)),
            ("Inflação", Snapshot.Inflation, MacroDisplay.Inflation(Snapshot.Inflation)),
            ("Risco", Snapshot.RiskSentiment, MacroDisplay.Regime(Snapshot.RiskSentiment))
        ];

    private static string HeatClass(string level) => level switch
    {
        "High" or "VeryHigh" or "Bullish" => "heat-high",
        "Low" or "VeryLow" or "Bearish" => "heat-low",
        _ => "heat-neutral"
    };
}

<style>
    .macro-heatmap { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; }
    .macro-heat-cell { padding: 0.75rem; border-radius: 8px; display: grid; gap: 0.25rem; text-align: center; font-size: 0.85rem; }
    .heat-high { background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.35); }
    .heat-low { background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3); }
    .heat-neutral { background: rgba(148,163,184,0.1); border: 1px solid rgba(148,163,184,0.2); }
</style>
