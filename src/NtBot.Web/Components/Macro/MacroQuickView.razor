@namespace NtBot.Web.Components.Macro

<div class="macro-quick-grid">
    <MacroScoreCard MacroScore="@Snapshot?.MacroScore" />
    <MacroRegimeCard Snapshot="@Snapshot" />
    <MacroRecommendationCard Recommendations="@Snapshot?.Recommendations" />
    <MacroConfidenceCard Confidence="@(Snapshot?.Confidence ?? 0)" MacroScore="@Snapshot?.MacroScore" />
</div>

@code {
    [Parameter] public MacroSnapshotModel? Snapshot { get; set; }
}

<style>
    .macro-quick-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1rem;
    }
</style>
