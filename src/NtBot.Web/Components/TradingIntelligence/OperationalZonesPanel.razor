@namespace NtBot.Web.Components.TradingIntelligence

<div class="nt-card md-card">
    <h3 class="md-section-title">Operational Zones</h3>
    @if (Zones.Count == 0)
    {
        <p class="app-muted">Nenhuma zona operacional identificada.</p>
    }
    else
    {
        <div class="ti-zones ti-scroll-panel-sm">
            @foreach (var zone in Zones)
            {
                <div class="ti-zone @ZoneClass(zone.Type)">
                    <strong>@zone.Label</strong>
                    <span class="app-muted">@zone.Timeframe · @zone.ConfluenceScore</span>
                    @if (zone.PriceHigh > zone.PriceLow)
                    {
                        <span>@zone.PriceLow.ToString("N2") — @zone.PriceHigh.ToString("N2")</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(zone.Description))
                    {
                        <p>@zone.Description</p>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<OperationalZoneModel> Zones { get; set; } = [];

    private static string ZoneClass(string type) => type switch
    {
        "StrongBuy" => "ti-zone-buy",
        "ModerateBuy" => "ti-zone-mod-buy",
        "StrongSell" => "ti-zone-sell",
        "ModerateSell" => "ti-zone-mod-sell",
        _ => "ti-zone-neutral"
    };
}

