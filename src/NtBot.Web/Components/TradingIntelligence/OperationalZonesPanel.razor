@namespace NtBot.Web.Components.TradingIntelligence

<div class="nt-card md-card">
    <h3 class="md-section-title">Operational Zones</h3>
    @if (Zones.Count == 0)
    {
        <p class="app-muted">Nenhuma zona operacional identificada.</p>
    }
    else
    {
        <div class="ti-zones">
            @foreach (var zone in Zones)
            {
                <div class="ti-zone @ZoneClass(zone.Type)">
                    <strong>@zone.Label</strong>
                    <span class="app-muted">@zone.Timeframe · Score @zone.ConfluenceScore</span>
                    @if (zone.PriceHigh > zone.PriceLow)
                    {
                        <span>@zone.PriceLow.ToString("N2") — @zone.PriceHigh.ToString("N2")</span>
                    }
                    <p style="margin:0.25rem 0 0;font-size:0.85rem;">@zone.Description</p>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<OperationalZoneModel> Zones { get; set; } = [];

    private static string ZoneClass(string type) => type switch
    {
        "StrongBuy" => "ti-zone-buy",
        "ModerateBuy" => "ti-zone-mod-buy",
        "StrongSell" => "ti-zone-sell",
        "ModerateSell" => "ti-zone-mod-sell",
        _ => "ti-zone-neutral"
    };
}

<style>
    .ti-zones { display:grid; gap:0.5rem; }
    .ti-zone { padding:0.65rem; border-radius:6px; border:1px solid rgba(255,255,255,0.08); display:grid; gap:0.15rem; font-size:0.85rem; }
    .ti-zone-buy { border-color: rgba(34,197,94,0.35); background: rgba(34,197,94,0.08); }
    .ti-zone-mod-buy { border-color: rgba(34,197,94,0.2); }
    .ti-zone-sell { border-color: rgba(239,68,68,0.35); background: rgba(239,68,68,0.08); }
    .ti-zone-mod-sell { border-color: rgba(239,68,68,0.2); }
</style>
