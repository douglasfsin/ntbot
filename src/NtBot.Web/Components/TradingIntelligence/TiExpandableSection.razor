@namespace NtBot.Web.Components.TradingIntelligence

<div class="ti-expandable @(Expanded ? "expanded" : "collapsed")">
    <div class="ti-expandable-body @BodyClass">
        @ChildContent
    </div>
    @if (ShowToggle)
    {
        <button type="button" class="ti-expand-toggle" @onclick="Toggle">
            @(Expanded ? CollapseLabel : ExpandLabel)
        </button>
    }
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool Expanded { get; set; }
    [Parameter] public EventCallback<bool> ExpandedChanged { get; set; }
    [Parameter] public string ExpandLabel { get; set; } = "Ver mais";
    [Parameter] public string CollapseLabel { get; set; } = "Ver menos";
    [Parameter] public string BodyClass { get; set; } = "";
    [Parameter] public bool ShowToggle { get; set; } = true;

    private async Task Toggle()
    {
        Expanded = !Expanded;
        await ExpandedChanged.InvokeAsync(Expanded);
    }
}
