@namespace NtBot.Web.Components.TradingIntelligence
@inject TradingIntelligenceApiClient TiApi

<div class="nt-card" style="grid-column:1/-1;">
    <h2 style="margin:0 0 1rem;font-size:1rem;">Trading Intelligence</h2>
    @if (_loading)
    {
        <p class="app-muted">Carregando status...</p>
    }
    else if (_status is null)
    {
        <p class="app-muted">Status indisponível.</p>
    }
    else
    {
        <dl class="app-dl">
            <dt>Redis cache</dt>
            <dd>
                @if (_status.RedisEnabled)
                {
                    <span class="nt-badge nt-badge-success">Ativo</span>
                }
                else
                {
                    <span class="nt-badge">Memória local</span>
                }
            </dd>
            <dt>IA (n8n)</dt>
            <dd>
                @if (_status.N8nConfigured)
                {
                    <span class="nt-badge nt-badge-success">Live · @_status.AiMode</span>
                }
                else
                {
                    <span class="nt-badge">Stub local</span>
                }
            </dd>
            <dt>Webhooks por ativo</dt>
            <dd>@_status.N8nAssetWebhooks (WIN, WDO, …)</dd>
            <dt>Dashboard</dt>
            <dd>@string.Join(", ", _status.DashboardAssets)</dd>
        </dl>
        <div class="ti-settings-actions">
            <button type="button" class="nt-btn nt-btn-accent ti-refresh-ia-btn" disabled="@_refreshing" @onclick="RefreshAllAsync">
                @(_refreshing ? "Atualizando IA…" : "Atualizar IA (todos os ativos)")
            </button>
            @if (!string.IsNullOrEmpty(_refreshMessage))
            {
                <span class="app-muted ti-refresh-msg">@_refreshMessage</span>
            }
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private bool _refreshing;
    private string? _refreshMessage;
    private TradingIntelligenceStatusModel? _status;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _status = await TiApi.GetStatusAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshAllAsync()
    {
        _refreshing = true;
        _refreshMessage = null;
        try
        {
            var ok = await TiApi.RefreshAsync();
            _refreshMessage = ok ? "IA atualizada via n8n para todos os ativos." : "Falha no refresh.";
        }
        catch (Exception ex)
        {
            _refreshMessage = ex.Message;
        }
        finally
        {
            _refreshing = false;
        }
    }
}

<style>
    .ti-settings-actions {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-top: 0.75rem;
        align-items: flex-start;
    }
    .ti-settings-actions .ti-refresh-msg {
        font-size: 0.8rem;
        color: var(--nt-success);
    }
</style>
