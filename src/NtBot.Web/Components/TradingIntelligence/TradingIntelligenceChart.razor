@namespace NtBot.Web.Components.TradingIntelligence
@inject TradingIntelligenceApiClient TiApi
@inject IJSRuntime Js
@implements IAsyncDisposable

<div class="nt-card md-card ti-chart-card ti-chart-hero">
    <header class="ti-chart-header">
        <div>
            <h3 class="md-section-title" style="margin:0;">Gráfico SMC — @SelectedTimeframe min</h3>
            @if (!string.IsNullOrEmpty(_candleSource))
            {
                <span class="ti-chart-source app-muted">Fonte: @_candleSource</span>
            }
        </div>
        <div class="ti-tf-tabs">
            @foreach (var tf in TabTimeframes)
            {
                <button type="button" class="ti-tf-tab @(SelectedTimeframe == tf ? "active" : "")"
                        @onclick="() => SelectTimeframeAsync(tf)">
                    @tf min
                </button>
            }
        </div>
    </header>

    @if (_loading)
    {
        <p class="app-muted ti-chart-status">Carregando candles…</p>
    }
    else if (!string.IsNullOrEmpty(_error))
    {
        <p class="app-muted ti-chart-status ti-chart-error">@_error</p>
    }
    else
    {
        <div id="@_containerId" class="ti-lw-chart ti-lw-chart-hero"></div>
        @if (ActiveTf is not null)
        {
            <div class="ti-tf-scores">
                <span>Wyckoff @ActiveTf.WyckoffScore</span>
                <span>SMC @ActiveTf.SmcScore</span>
                <span>Volume @ActiveTf.VolumeScore</span>
            </div>
        }
        @if (HighConfluenceIntersections.Any())
        {
            <div class="ti-intersections">
                @foreach (var i in HighConfluenceIntersections.Take(3))
                {
                    <span class="ti-intersection-chip" title="@i.Pair">
                        @i.Pair · @i.ConfluenceScore
                    </span>
                }
            </div>
        }
    }
</div>

@code {
    private static readonly string[] DefaultTimeframes = ["5", "15", "30", "60"];

    [Parameter] public string Symbol { get; set; } = "WIN";
    [Parameter] public IReadOnlyList<TimeframeAnalysisModel> Timeframes { get; set; } = [];
    [Parameter] public IReadOnlyList<TimeframeIntersectionModel> Intersections { get; set; } = [];
    [Parameter] public IReadOnlyList<OperationalZoneModel> Zones { get; set; } = [];

    private string SelectedTimeframe { get; set; } = "60";
    private readonly string _containerId = $"ti-chart-{Guid.NewGuid():N}";
    private bool _scriptsLoaded;
    private bool _loading = true;
    private bool _renderPending;
    private string? _error;
    private string? _candleSource;

    private IEnumerable<string> TabTimeframes =>
        Timeframes.Count > 0
            ? Timeframes.Select(t => t.Timeframe)
            : DefaultTimeframes;

    private TimeframeAnalysisModel? ActiveTf =>
        Timeframes.FirstOrDefault(t => t.Timeframe == SelectedTimeframe) ?? Timeframes.FirstOrDefault();

    private IEnumerable<TimeframeIntersectionModel> HighConfluenceIntersections =>
        Intersections.Where(i => i.HighConfluence);

    protected override void OnParametersSet()
    {
        var tabs = TabTimeframes.ToList();
        if (tabs.Count > 0 && !tabs.Contains(SelectedTimeframe))
            SelectedTimeframe = tabs[^1];

        _renderPending = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_renderPending)
            return;

        _renderPending = false;
        await RenderChartAsync();
    }

    private async Task SelectTimeframeAsync(string tf)
    {
        SelectedTimeframe = tf;
        _renderPending = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task RenderChartAsync()
    {
        if (string.IsNullOrWhiteSpace(Symbol))
            return;

        _loading = true;
        _error = null;
        _candleSource = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            await EnsureScriptsAsync();

            var (candles, source) = await TiApi.GetChartCandlesAsync(Symbol, SelectedTimeframe);
            if (candles.Count == 0)
            {
                _error = "Candles indisponíveis. Configure MT5/OHLCV ou aguarde sync.";
                return;
            }

            _candleSource = source switch
            {
                "mt5" or "mt5-partial" => "MT5 live",
                "database" or "database-stale" => "PostgreSQL",
                "synthetic" => "Regiões (preview)",
                _ => source
            };

            var smcOverlays = await TiApi.GetSmcOverlaysAsync(Symbol, SelectedTimeframe);

            var zonePayload = Zones
                .Where(z => string.IsNullOrWhiteSpace(z.Timeframe) || z.Timeframe == SelectedTimeframe || z.Timeframe.Contains(SelectedTimeframe))
                .Take(4)
                .Select(z => new { label = z.Label, type = z.Type, priceLow = z.PriceLow, priceHigh = z.PriceHigh })
                .ToList();

            var overlayPayload = smcOverlays
                .Select(z => new { label = z.Label, type = z.Type, priceLow = z.PriceLow, priceHigh = z.PriceHigh })
                .ToList();

            await Js.InvokeVoidAsync("tiChart.render", _containerId, candles, zonePayload, overlayPayload, 320);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task EnsureScriptsAsync()
    {
        if (_scriptsLoaded) return;
        await Js.InvokeVoidAsync("eval", @"
            if (!window.__tiLwLoaded) {
                const s = document.createElement('script');
                s.src = 'https://unpkg.com/lightweight-charts@4.2.0/dist/lightweight-charts.standalone.production.js';
                document.head.appendChild(s);
                window.__tiLwLoaded = true;
            }");
        for (var i = 0; i < 30; i++)
        {
            var ready = await Js.InvokeAsync<bool>("eval", "typeof LightweightCharts !== 'undefined'");
            if (ready) break;
            await Task.Delay(100);
        }
        _scriptsLoaded = true;
    }

    public async ValueTask DisposeAsync()
    {
        try { await Js.InvokeVoidAsync("tiChart.dispose", _containerId); } catch { /* page unload */ }
    }
}
