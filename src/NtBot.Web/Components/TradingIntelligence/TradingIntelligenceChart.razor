@namespace NtBot.Web.Components.TradingIntelligence
@inject TradingIntelligenceApiClient TiApi
@inject IJSRuntime Js
@implements IAsyncDisposable

<div class="nt-card md-card ti-chart-card">
    <h3 class="md-section-title">Gráfico — @SelectedTimeframe min</h3>
    @if (Timeframes.Count == 0)
    {
        <p class="app-muted">Sem dados de candle para regiões.</p>
    }
    else
    {
        <div class="ti-tf-tabs">
            @foreach (var tf in Timeframes)
            {
                <button type="button" class="ti-tf-tab @(SelectedTimeframe == tf.Timeframe ? "active" : "")"
                        @onclick="() => SelectTimeframeAsync(tf.Timeframe)">
                    @tf.Timeframe min
                </button>
            }
        </div>
        <div id="@_containerId" class="ti-lw-chart"></div>
        @if (ActiveTf is not null)
        {
            <div class="ti-tf-scores">
                <span>Wyckoff @ActiveTf.WyckoffScore</span>
                <span>SMC @ActiveTf.SmcScore</span>
                <span>Volume @ActiveTf.VolumeScore</span>
            </div>
        }
        @if (HighConfluenceIntersections.Any())
        {
            <div class="ti-intersections">
                @foreach (var i in HighConfluenceIntersections.Take(3))
                {
                    <span class="ti-intersection-chip" title="@i.Pair">
                        @i.Pair · @i.ConfluenceScore
                    </span>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public string Symbol { get; set; } = "WIN";
    [Parameter] public IReadOnlyList<TimeframeAnalysisModel> Timeframes { get; set; } = [];
    [Parameter] public IReadOnlyList<TimeframeIntersectionModel> Intersections { get; set; } = [];
    [Parameter] public IReadOnlyList<OperationalZoneModel> Zones { get; set; } = [];

    private string SelectedTimeframe { get; set; } = "60";
    private readonly string _containerId = $"ti-chart-{Guid.NewGuid():N}";
    private bool _scriptsLoaded;

    private TimeframeAnalysisModel? ActiveTf =>
        Timeframes.FirstOrDefault(t => t.Timeframe == SelectedTimeframe) ?? Timeframes.FirstOrDefault();

    private IEnumerable<TimeframeIntersectionModel> HighConfluenceIntersections =>
        Intersections.Where(i => i.HighConfluence);

    protected override async Task OnParametersSetAsync()
    {
        if (Timeframes.Count > 0 && !Timeframes.Any(t => t.Timeframe == SelectedTimeframe))
            SelectedTimeframe = Timeframes[0].Timeframe;

        await RenderChartAsync();
    }

    private async Task SelectTimeframeAsync(string tf)
    {
        SelectedTimeframe = tf;
        await RenderChartAsync();
    }

    private async Task RenderChartAsync()
    {
        if (string.IsNullOrWhiteSpace(Symbol) || Timeframes.Count == 0)
            return;

        await EnsureScriptsAsync();

        var candles = await TiApi.GetChartCandlesAsync(Symbol, SelectedTimeframe);
        if (candles.Count == 0)
            return;

        var smcOverlays = await TiApi.GetSmcOverlaysAsync(Symbol, SelectedTimeframe);

        var zonePayload = Zones
            .Where(z => string.IsNullOrWhiteSpace(z.Timeframe) || z.Timeframe == SelectedTimeframe || z.Timeframe.Contains(SelectedTimeframe))
            .Take(4)
            .Select(z => new { label = z.Label, type = z.Type, priceLow = z.PriceLow, priceHigh = z.PriceHigh })
            .ToList();

        var overlayPayload = smcOverlays
            .Select(z => new { label = z.Label, type = z.Type, priceLow = z.PriceLow, priceHigh = z.PriceHigh })
            .ToList();

        await Js.InvokeVoidAsync("tiChart.render", _containerId, candles, zonePayload, overlayPayload);
    }

    private async Task EnsureScriptsAsync()
    {
        if (_scriptsLoaded) return;
        await Js.InvokeVoidAsync("eval", @"
            if (!window.__tiLwLoaded) {
                const s = document.createElement('script');
                s.src = 'https://unpkg.com/lightweight-charts@4.2.0/dist/lightweight-charts.standalone.production.js';
                document.head.appendChild(s);
                window.__tiLwLoaded = true;
            }");
        for (var i = 0; i < 20; i++)
        {
            var ready = await Js.InvokeAsync<bool>("eval", "typeof LightweightCharts !== 'undefined'");
            if (ready) break;
            await Task.Delay(100);
        }
        _scriptsLoaded = true;
    }

    public async ValueTask DisposeAsync()
    {
        try { await Js.InvokeVoidAsync("tiChart.dispose", _containerId); } catch { /* page unload */ }
    }
}

<style>
    .ti-lw-chart { width: 100%; height: 160px; margin: 0.25rem 0; }
    .ti-tf-tabs { display:flex; gap:0.25rem; margin-bottom:0.35rem; flex-wrap:wrap; }
    .ti-tf-tab { padding:0.2rem 0.45rem; border-radius:4px; border:1px solid rgba(255,255,255,0.12); background:transparent; color:inherit; cursor:pointer; font-size:0.7rem; }
    .ti-tf-tab.active { background: var(--nt-accent, #3b82f6); border-color: transparent; }
    .ti-tf-scores { display:flex; gap:0.65rem; font-size:0.7rem; color: var(--nt-text-secondary); flex-wrap:wrap; }
    .ti-intersections { display:flex; flex-wrap:wrap; gap:0.25rem; margin-top:0.35rem; }
    .ti-intersection-chip { font-size:0.68rem; padding:0.15rem 0.35rem; border-radius:999px; background:rgba(255,255,255,0.06); color:var(--nt-text-secondary); }
</style>
