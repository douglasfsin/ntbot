@namespace NtBot.Web.Components.TradingIntelligence

<div class="nt-card md-card ti-confluence-card @(Compact ? "ti-confluence-compact" : "")">
    <header class="md-card-header ti-confluence-header">
        <h3 class="md-section-title" style="margin:0;">Confluence Score</h3>
        @if (Confluence is not null)
        {
            <div class="ti-score-inline">
                <strong class="ti-score-value">@Confluence.Score</strong>
                <span class="app-muted">/100 · @Confluence.Recommendation</span>
                <span class="nt-badge @BadgeClass">@Confluence.Classification</span>
            </div>
        }
    </header>
    @if (Confluence is not null)
    {
        <div class="ti-bars">
            @foreach (var c in Confluence.Components)
            {
                <div class="ti-bar-row">
                    <span class="ti-bar-label">@c.Engine</span>
                    <div class="md-progress"><div class="md-progress-bar" style="width:@(c.Score)%"></div></div>
                    <span class="ti-bar-score">@c.Score</span>
                </div>
            }
        </div>
        @if (!Compact && !string.IsNullOrWhiteSpace(Confluence.Explanation))
        {
            <p class="md-explanation ti-confluence-explanation">@Confluence.Explanation</p>
        }
    }
</div>

@code {
    [Parameter] public ConfluenceScoreModel? Confluence { get; set; }
    [Parameter] public bool Compact { get; set; } = true;

    private string BadgeClass => Confluence?.Score switch
    {
        >= 85 => "nt-badge-success",
        <= 30 => "nt-badge-danger",
        _ => ""
    };
}

<style>
    .ti-confluence-header { display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:0.5rem; margin-bottom:0.5rem; }
    .ti-score-inline { display:flex; align-items:baseline; gap:0.35rem; flex-wrap:wrap; font-size:0.85rem; }
    .ti-score-value { font-size:1.35rem; line-height:1; font-weight:700; }
    .ti-bars { display:grid; gap:0.25rem; }
    .ti-bar-row { display:grid; grid-template-columns: 72px 1fr 28px; gap:0.35rem; align-items:center; font-size:0.75rem; }
    .ti-bar-label { color: var(--nt-text-secondary); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .ti-bar-score { text-align:right; font-variant-numeric: tabular-nums; }
    .md-progress { height:5px; background:rgba(255,255,255,0.08); border-radius:999px; overflow:hidden; }
    .md-progress-bar { height:100%; background:var(--nt-accent); border-radius:999px; }
    .ti-confluence-compact .ti-bars { grid-template-columns: repeat(2, 1fr); column-gap:0.75rem; }
    .ti-confluence-explanation { margin:0.75rem 0 0; font-size:0.85rem; color:var(--nt-text-secondary); }
</style>
