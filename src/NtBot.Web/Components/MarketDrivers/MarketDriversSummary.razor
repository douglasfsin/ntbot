@namespace NtBot.Web.Components.MarketDrivers

@if (Snapshot is not null)
{
    <div class="nt-card md-summary">
        <header class="md-summary-header">
            <div>
                <h2 style="margin:0;">@Snapshot.Asset</h2>
                <span class="app-muted">Market Drivers</span>
            </div>
            <span class="nt-badge @MarketDriversDisplay.ScoreBadgeClass(Snapshot.Score.Score)">@Snapshot.Score.Recommendation</span>
        </header>

        <div class="md-summary-grid">
            <MarketDriversGauge Score="Snapshot.Score.Score" Label="@Snapshot.Score.Classification" />
            <div class="md-metrics">
                <div><span class="app-metric-label">Score</span><strong>@Snapshot.Score.Score/100</strong></div>
                <div><span class="app-metric-label">Confiança</span><strong>@Snapshot.Score.Confidence.ToString("F0")%</strong></div>
                @if (Snapshot.Score.QuantProbability is not null)
                {
                    <div><span class="app-metric-label">Prob. Quant</span><strong>@Snapshot.Score.QuantProbability.Value.ToString("F0")%</strong></div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public MarketDriversSnapshotModel? Snapshot { get; set; }
}
