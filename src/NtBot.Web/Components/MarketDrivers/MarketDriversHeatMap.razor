@namespace NtBot.Web.Components.MarketDrivers

@if (Cells.Count > 0)
{
    var groups = Cells.GroupBy(c => c.Group).ToList();
    <div class="md-heatmap-section">
        @foreach (var group in groups)
        {
            <div>
                @if (groups.Count > 1)
                {
                    <h4 class="md-sub-title">@group.Key</h4>
                }
                <div class="md-heatmap">
                    @foreach (var cell in group)
                    {
                        <div class="md-heat-cell @MarketDriversDisplay.HeatClass(cell.Score)" title="@cell.Tooltip">
                            <div>@cell.Label</div>
                            <strong>@cell.Score</strong>
                            <span class="app-muted" style="font-size:0.75rem;">@cell.Variation.ToString("+0.0;-0.0;0.0")</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public IReadOnlyList<MarketDriverHeatCellModel> Cells { get; set; } = [];
}
