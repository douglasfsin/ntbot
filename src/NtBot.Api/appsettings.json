{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "NinjaTrader": {
    "ApiBaseUrl": "http://localhost:8080",
    "WebSocketUrl": "ws://localhost:8080/ws",
    "DefaultAccount": "Sim101"
  },
  "Jwt": {
    "Key": "your-super-secret-key-minimum-32-characters-long-for-production",
    "Issuer": "NTBot",
    "Audience": "NTBotUsers",
    "ExpirationMinutes": 1440
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "EnableSsl": true,
    "FromEmail": "",
    "FromName": "NTBot",
    "Username": "",
    "Password": ""
  },
  "Trading": {
    "DefaultSymbol": "MNQ",
    "DefaultTimeframes": [ "1m", "5m", "15m", "1h", "1d" ],
    "MaxConcurrentPositions": 3,
    "DefaultRiskPercentage": 1.5,
    "MinConfidenceScore": 70.0,
    "MinRiskRewardRatio": 2.0
  },
  "Wyckoff": {
    "MinRangeCandles": 10,
    "SpringPenetrationPercent": 0.002,
    "RejectionRatio": 0.7,
    "VolumeLookback": 20
  },
  "Macro": {
    "ReferenceSymbols": [ "ES", "NQ", "DXY", "VIX" ],
    "CorrelationPeriodDays": 30,
    "VixBlockThreshold": 30,
    "VixReduceThreshold": 20
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
